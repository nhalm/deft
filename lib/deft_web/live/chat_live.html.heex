<div class="chat-container" phx-window-keydown="keydown">
  <div class="header-bar">
    <div class="header-left">
      <span class="app-name">Deft</span>
      <span class="separator">—</span>
      <span class="repo-name"><%= @repo_name %></span>
    </div>
    <div class="header-center">
      <span class="agent-identity"><%= @agent_identity %></span>
      <span class={"state-indicator state-#{@agent_state}"}>
        ◉ <%= @agent_state %>
      </span>
    </div>
    <div class="header-right">
      <button>⚙</button>
      <button>📋</button>
      <button>?</button>
    </div>
  </div>

  <div class="conversation-area" id="conversation-area" phx-hook="ScrollControl">
      <div phx-update="stream" id="conversation">
        <%= for {id, item} <- @streams.conversation do %>
          <div id={id} class="conversation-item">
            <%= render_conversation_item(item) %>
          </div>
        <% end %>
      </div>

      <div id="streaming-content">
        <%= if @streaming_thinking != "" do %>
          <.thinking
            id="streaming-thinking"
            content={@streaming_thinking}
            expanded={Map.get(@thinking_blocks_expanded, "streaming-thinking", true)}
          />
        <% end %>

        <%= if @streaming_text != "" do %>
          <div class="streaming-text" id="streaming-text-block">
            <%= @streaming_text %><span class="cursor">▊</span>
          </div>
        <% end %>

        <%= for {tool_id, tool} <- @active_tools do %>
          <.tool_call
            id={"tool-#{tool_id}"}
            name={tool.name}
            status={tool.status}
            duration={tool.duration}
            input={tool.input}
            output={tool.output}
            expanded={Map.get(@tools_expanded, "tool-#{tool_id}", false)}
          />
        <% end %>
      </div>
    </div>

  <.roster agents={@agent_statuses} visible={@roster_visible or @job_active} />

  <div class="input-area">
    <form phx-submit="submit">
      <textarea
        name="input"
        id="input"
        phx-hook="TextareaInput"
        data-vim-mode={@vim_mode}
        placeholder="Enter a prompt or command..."
        class="chat-input"
      ><%= @input %></textarea>
    </form>
    <span class="mode-indicator"><%= mode_indicator(@vim_mode) %></span>
  </div>

  <%= if @job_active do %>
    <.status_bar
      mode={:orchestration}
      lead_count={count_leads(@agent_statuses)}
      completed={count_completed_leads(@agent_statuses)}
      total={count_leads(@agent_statuses)}
      cost={@cost}
      cost_limit={@job_budget}
      elapsed_seconds={compute_elapsed_seconds(@job_started_at)}
      state={@agent_state}
    />
  <% else %>
    <.status_bar
      mode={:solo}
      tokens_used={@tokens_input + @tokens_output}
      tokens_max={200_000}
      memory_tokens={@om_memory_tokens}
      memory_max={40_000}
      cost={@cost}
      turn={@turn_count}
      turn_limit={@turn_limit}
      state={@agent_state}
    />
  <% end %>
</div>
