<div class={"chat-container #{unless @roster_visible or @job_active, do: "roster-hidden"}"} phx-window-keydown="keydown">
  <div class="header-bar">
    <div class="header-left">
      <span class="app-name">Deft</span>
      <span class="separator">—</span>
      <span class="repo-name"><%= @repo_name %></span>
    </div>
    <div class="header-center">
      <span class={"state-indicator state-#{@agent_state}"}>◉</span>
    </div>
    <div class="header-right">
      <button class="header-button" phx-click="new_session">New</button>
      <a href="/sessions" target="_blank" class="header-button">Sessions</a>
      <button class="header-button" phx-click="show_help">Help</button>
    </div>
  </div>

  <div class="conversation-area" id="conversation-area" phx-hook="ScrollControl">
      <div phx-update="stream" id="conversation" phx-hook="SyntaxHighlight">
        <%= for {id, item} <- @streams.conversation do %>
          <div id={id} class="conversation-item">
            <.render_conversation_item item={item} thinking_expanded={@thinking_blocks_expanded} tools_expanded={@tools_expanded} session_id={@session_id} />
          </div>
        <% end %>
      </div>

      <div id="streaming-content">
        <%= if @agent_state != :idle do %>
          <div class="activity-indicator">
            <span class="activity-spinner"></span>
            <span class="activity-label"><%= activity_label(@agent_state) %></span>
          </div>
        <% end %>

        <%= if @streaming_thinking != "" do %>
          <.thinking
            id="streaming-thinking"
            content={@streaming_thinking}
            expanded={Map.get(@thinking_blocks_expanded, "streaming-thinking", true)}
          />
        <% end %>

        <div class={"streaming-text conversation-item #{if @streaming_text == "", do: "hidden"}"} id="streaming-text-block" phx-hook="StreamingMarkdown">
          <div class="streaming-markdown-content"></div><span class="cursor">▊</span>
        </div>

        <%= for {tool_id, tool} <- @active_tools do %>
          <.tool_call
            id={"tool-#{tool_id}"}
            name={tool.name}
            key_arg={tool.key_arg}
            status={tool.status}
            duration={tool.duration}
          />
        <% end %>

        <%= if @turn_limit_reached do %>
          <div class="turn-limit-prompt">
            <p class="turn-limit-message">
              The agent has reached the turn limit. Would you like to continue or abort?
            </p>
            <div class="turn-limit-actions">
              <button phx-click="continue_turn" class="btn-continue">Continue</button>
              <button phx-click="abort_turn" class="btn-abort">Abort</button>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  <.roster agents={@agent_statuses} visible={@roster_visible or @job_active} />

  <div class="input-area">
    <form phx-submit="submit" class="input-form">
      <textarea
        name="input"
        id="input"
        phx-hook="TextareaInput"
        data-vim-mode={@vim_mode}
        placeholder="Enter a prompt or command..."
        class="chat-input"
      ><%= @input %></textarea>
    </form>
    <span class={"vim-mode-indicator #{@vim_mode}"}><%= mode_indicator(@vim_mode) %></span>
  </div>

  <%= if @job_active do %>
    <.status_bar
      mode={:orchestration}
      lead_count={count_leads(@agent_statuses)}
      completed={count_completed_leads(@agent_statuses)}
      total={count_leads(@agent_statuses)}
      cost={@cost}
      cost_limit={@job_budget}
      elapsed_seconds={compute_elapsed_seconds(@job_started_at)}
      state={@agent_state}
    />
  <% else %>
    <.status_bar
      mode={:solo}
      tokens_used={@tokens_input + @tokens_output}
      tokens_max={200_000}
      memory_tokens={@om_memory_tokens}
      memory_max={40_000}
      cost={@cost}
      turn={@turn_count}
      turn_limit={@turn_limit}
      state={@agent_state}
    />
  <% end %>

  <%= if @help_visible do %>
    <div class="help-overlay" phx-click="show_help">
      <div class="help-content" phx-click="prevent_close">
        <div class="help-header">
          <h2>Help</h2>
          <button class="close-button" phx-click="show_help">×</button>
        </div>
        <div class="help-body">
          <h3>Available Commands</h3>
          <dl>
            <dt>/help</dt>
            <dd>Show this help screen</dd>

            <dt>/model &lt;name&gt;</dt>
            <dd>Switch the LLM model (e.g., /model claude-3-opus)</dd>

            <dt>/clear</dt>
            <dd>Clear the conversation display</dd>

            <dt>/compact</dt>
            <dd>Force message compaction</dd>

            <dt>/observations</dt>
            <dd>Show observational memory observations</dd>

            <dt>/forget &lt;text&gt;</dt>
            <dd>Mark an observation for removal</dd>

            <dt>/correct &lt;old&gt; -&gt; &lt;new&gt;</dt>
            <dd>Mark an observation for correction</dd>

            <dt>/cost</dt>
            <dd>Show detailed cost breakdown</dd>

            <dt>/status</dt>
            <dd>Show orchestration job status</dd>

            <dt>/inspect &lt;lead&gt;</dt>
            <dd>Show a Lead agent's site log entries</dd>

            <dt>/plan</dt>
            <dd>Re-display the approved plan</dd>

            <dt>/quit</dt>
            <dd>Stop the server and exit</dd>
          </dl>

          <h3>Keyboard Shortcuts</h3>
          <dl>
            <dt>Esc</dt>
            <dd>Switch to Normal mode</dd>

            <dt>i</dt>
            <dd>Switch to Insert mode (when in Normal)</dd>

            <dt>j / k</dt>
            <dd>Scroll down / up (when in Normal)</dd>

            <dt>G</dt>
            <dd>Scroll to bottom (when in Normal)</dd>

            <dt>gg</dt>
            <dd>Scroll to top (when in Normal)</dd>

            <dt>Ctrl+u / Ctrl+d</dt>
            <dd>Half-page scroll up / down</dd>

            <dt>Ctrl+b %</dt>
            <dd>Toggle agent roster panel</dd>

            <dt>Ctrl+c</dt>
            <dd>Abort agent operation</dd>

            <dt>Ctrl+c Ctrl+c</dt>
            <dd>Force abort</dd>
          </dl>
        </div>
      </div>
    </div>
  <% end %>
</div>
